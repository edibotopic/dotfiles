# Basics
alias ~='cd ~'
alias cls=clear
alias kbd='setxkbmap -layout us' # (re)set keyboard layout to us
alias wallg='$HOME/scripts/sh/wallpapers.sh' # gnome only
alias slp='sudo pm-suspend'
alias pk='pkill picom || picom -b --experimental-backends &' # xorg only
alias br='brightness-controller'
alias cl='journalctl --vacuum-time=10d' # clear recent logs

# (Neo)Vim
alias n=nvim # default kickstart nvim config
alias nv=nvim
alias nw='nv -c VimwikiIndex' # open vimwiki index
alias nf='nv $(fzf)' # fuzzy find and open in nvim
alias n0='$HOME/scripts/sh/nv0.sh' # minimal kickstart nvim config

# Git
alias g='lazygit'
alias lg='lazygit'
alias gr='cd $(git rev-parse --show-toplevel)'

# Multiplex
alias z=zellij
alias zj=zellij
alias zw='zellij --layout welcome'

# Files
alias y=yazi
alias yz=yazi
alias rng=ranger
alias open=xdg-open

# Development
alias dev='cd $HOME/dev/gh && lls'
alias srv='live-server'
alias process='$HOME/scripts/sh/process.sh'
alias love='/usr/bin/love.AppImage'
alias defold='$HOME/software/Defold/Defold'

# Documents
alias doc2pdf='libreoffice --headless --convert-to pdf *.doc' # convert all Word doc files to pdf
alias docx2pdf='libreoffice --headless --convert-to pdf *.docx' # convert all Word docs to pdf
alias odt2pdf='libreoffice --headless --convert-to pdf *.odt' # convert all .odt docs to pdf
alias ppt2pdf='libreoffice --headless --convert-to pdf *.pptx' # convert all .odt docs to pdf
alias foxit='/home/edibotopic/opt/foxitsoftware/foxitreader/FoxitReader'
alias xr='/home/edibotopic/software/dita-ot/bin/dita' # tool to convert xml source to docs

# Python
alias py=python3
alias python=python3
alias envmk='py -m venv env'
alias envac='source ./env/bin/activate'
alias deac=deactivate

# Quarto
alias qp='quarto preview'
alias qr='quarto render'

# Wacom
alias sx='source $HOME/.xinitrc' # sets buttons for Wacom pen
alias wacompc='source $HOME/scripts/sh/wacom-multimon.sh' # restricts to 180p screen for dual monitor setup

# Data
alias weather='curl wttr.in/Cork'

# Reading
alias rss='newsboat'

# Terminal
alias ghostty='/home/edibotopic/opt/ghostty/zig-out/bin/ghostty'
alias wezterm='flatpak run org.wezfurlong.wezterm'
